# Environment file for idrac-power-mqtt.service
# Copy to /etc/idrac-power-mqtt/env and edit

IDRAC_MQTT_HOST=127.0.0.1
IDRAC_MQTT_PORT=1883
IDRAC_MQTT_TOPIC_PREFIX=homelab/idrac
IDRAC_PUBLISH_HOME_ASSISTANT_DISCOVERY=1
IDRAC_DISCOVERY_EXPIRE_AFTER_SECONDS=180
IDRAC_IPMI_USER=root
IDRAC_IPMI_PASSWORD=calvin
IDRAC_DIRECT_SSH_TIMEOUT_SECONDS=10
IDRAC_INTERACTIVE_SSH_TIMEOUT_SECONDS=30
IDRAC_IPMI_COLLECTION_TIMEOUT_SECONDS=15
IDRAC_MQTT_PUBLISH_TIMEOUT_SECONDS=10
IDRAC_SSH_CONNECT_TIMEOUT_SECONDS=5

# Uncomment for authenticated MQTT
# IDRAC_MQTT_USERNAME=
# IDRAC_MQTT_PASSWORD=
# IDRAC_MQTT_QOS=1
